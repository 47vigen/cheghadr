{
  "name": "cheghadr",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --inspect",
    "build": "prisma generate && next build --turbopack",
    "check": "pnpm typecheck && pnpm lint",
    "format": "biome format .",
    "format:write": "biome format --write --max-diagnostics 0 .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics 0 .",
    "biome:fix": "biome check --write --unsafe --max-diagnostics 0 .",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "swagger:gen": "KUBB_DISABLE_TELEMETRY=1 kubb generate",
    "swagger": "pnpm swagger:gen && pnpm biome:fix",
    "postinstall": "prisma generate",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,mdx}": [
      "biome check --write --unsafe"
    ]
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/query-sync-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@telegram-apps/sdk": "^3.11.8",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@telegram-apps/telegram-ui": "^2.1.13",
    "@trpc/client": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@twa-dev/sdk": "^8.0.2",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "4.1.0-0",
    "deep-cleaner": "2.0.0-alpha.3",
    "jotai": "^2.18.1",
    "lodash-es": "^4.17.23",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "prisma": "^7.5.0",
    "qs": "^6.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@kubb/agent": "^4.34.0",
    "@kubb/cli": "^4.34.0",
    "@kubb/core": "^4.34.0",
    "@kubb/plugin-client": "^4.34.0",
    "@kubb/plugin-oas": "^4.34.0",
    "@kubb/plugin-react-query": "^4.34.0",
    "@kubb/plugin-ts": "^4.34.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.1.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
