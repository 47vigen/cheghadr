{
  "name": "cheghadr",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --inspect",
    "build": "next build --turbopack",
    "check": "pnpm typecheck && pnpm lint",
    "format": "biome format .",
    "format:write": "biome format --write --max-diagnostics 0 .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics 0 .",
    "biome:fix": "biome check --write --unsafe --max-diagnostics 0 .",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "swagger:gen": "KUBB_DISABLE_TELEMETRY=1 kubb generate",
    "swagger": "pnpm swagger:gen && pnpm biome:fix",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,mdx}": [
      "biome check --write --unsafe"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/query-sync-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@telegram-apps/telegram-ui": "^2.1.13",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "4.1.0-0",
    "deep-cleaner": "2.0.0-alpha.3",
    "lodash-es": "^4.17.23",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "qs": "^6.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@kubb/agent": "^4.34.0",
    "@kubb/cli": "^4.34.0",
    "@kubb/core": "^4.34.0",
    "@kubb/plugin-client": "^4.34.0",
    "@kubb/plugin-oas": "^4.34.0",
    "@kubb/plugin-react-query": "^4.34.0",
    "@kubb/plugin-ts": "^4.34.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.1.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "shadcn": "^4.0.7",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
