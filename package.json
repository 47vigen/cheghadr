{
  "name": "cheghadr",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --inspect",
    "build": "prisma generate && next build --turbopack",
    "check": "pnpm typecheck && pnpm lint",
    "format": "biome format .",
    "format:write": "biome format --write --max-diagnostics 0 .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics 0 .",
    "biome:fix": "biome check --write --unsafe --max-diagnostics 0 .",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "swagger:gen": "KUBB_DISABLE_TELEMETRY=1 kubb generate",
    "swagger": "pnpm swagger:gen && pnpm biome:fix",
    "postinstall": "prisma generate",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,mdx}": [
      "biome check --write --unsafe"
    ]
  },
  "dependencies": {
    "@heroui/react": "3.0.1",
    "@heroui/styles": "3.0.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@telegram-apps/sdk": "^3.11.8",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@trpc/client": "^11.15.0",
    "@trpc/react-query": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "@twa-dev/sdk": "^8.0.2",
    "clsx": "^2.1.1",
    "jotai": "^2.18.1",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "prisma": "^7.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-variants": "^3.2.2",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@kubb/agent": "^4.36.3",
    "@kubb/cli": "^4.36.3",
    "@kubb/core": "^4.36.3",
    "@kubb/plugin-oas": "^4.36.3",
    "@kubb/plugin-ts": "^4.36.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
